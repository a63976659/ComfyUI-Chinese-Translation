    "智能缩放图像及遮罩": {
        "title": "Smart Resize Image & Mask",
        "inputs": {},
        "widgets": {
            "调整类型": "Resize Type",
            "插值方法": "Interpolation Method",
            "图像或遮罩": "Image or Mask",
            "参考图像": "Reference Image",
            "裁剪方式": "Crop Method",
            "宽度": "Width",
            "高度": "Height",
            "缩放系数": "Scale Factor",
            "指定长度": "Target Length",
            "百万像素": "Megapixels",
            "放大": "Upscale"
        },
        "outputs": {
            "图像/遮罩": "Image/Mask",
            "*": "*"
        },
        "description": "\n    Resize Type Description:\n    1. Exact Size/Width/Height: Force resize to specific pixels.\n    2. Scale Factor: Scale by multiplier (e.g., 0.5 or 2.0).\n    3. Target Long/Short Edge: Lock one edge length, other edge scales proportionally.\n    4. Target Pixels: Maintain aspect ratio, adjust total pixel count to approximate value (e.g., 1MP).\n    5. Match Image: Resize input image to match reference image dimensions.\n    6. To Multiple: 【Important】Adjust image dimensions to integer multiples of specified value (e.g., 8).\n       - Purpose: Fix non-standard size images to prevent SD VAE or video model errors due to indivisible dimensions.\n       - Algorithm: Scale proportionally to cover target size, then center crop.\n    ",
        "api_version": "V1"
    },
