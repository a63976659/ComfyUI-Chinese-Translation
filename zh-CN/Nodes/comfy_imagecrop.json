{
    "AutoResizeTo3": {
        "title": "自动调整至3的倍数",
        "inputs": {
            "image": "图像"
        },
        "widgets": {
            "mode": "模式"
        },
        "outputs": {
            "image": "图像",
            "width": "宽度",
            "height": "高度"
        },
        "description": "将图片调整到宽高均可被 3 整除，可选拉伸/裁剪/填充策略"
    },
    "AutoResizeTo8": {
        "title": "自动调整至8的倍数",
        "inputs": {
            "image": "图像"
        },
        "widgets": {
            "mode": "模式"
        },
        "outputs": {
            "image": "图像",
            "width": "宽度",
            "height": "高度"
        },
        "description": "将图片调整到宽高均可被 8 整除，可选拉伸/裁剪/填充策略"
    },
    "BatchGetImages": {
        "title": "批量获取图像",
        "inputs": {
            "images": "图像"
        },
        "widgets": {
            "indices": "索引",
            "keep_order": "保持顺序",
            "remove_duplicates": "移除重复",
            "allow_negative": "允许负索引"
        },
        "outputs": {
            "images": "图像批次"
        },
        "description": "🔵BB 提取图像（单个或多个-X） - 从图像批次中提取单个或多个图像，输出为新的图像批次\nComfyUI自定义节点"
    },
    "CurvePanel": {
        "title": "曲线面板",
        "inputs": {
            "image": "图像"
        },
        "widgets": {
            "channel": "通道",
            "curve_points": "曲线控制点"
        },
        "outputs": {
            "output_image": "输出图像",
            "preview_image": "预览图像"
        },
        "description": "曲线调整节点（带交互面板）\n支持在节点面板中交互编辑曲线（控制点拖拽/添加/删除），并将曲线参数同步到节点参数。"
    },
    "DepthAdjustNode": {
        "title": "深度图明暗调整",
        "inputs": {
            "image": "图像",
            "depth_map": "深度图"
        },
        "widgets": {
            "dark_intensity": "暗部强度",
            "dark_range": "暗部范围",
            "dark_feather": "暗部羽化",
            "light_intensity": "亮部强度",
            "light_range": "亮部范围",
            "light_feather": "亮部羽化",
            "dark_position": "暗部位置",
            "light_position": "亮部位置"
        },
        "outputs": {
            "image": "图像"
        },
        "description": "深度图明暗调整节点\n根据深度图调整图像的近处和远处明暗程度\n输入:\n    图像: 原图 (IMAGE)\n    深度图: 深度图 (IMAGE) - 白色=近处，黑色=远处\n参数:\n     暗部位置 (\"near\"=近处, \"far\"=远处)\n     暗部强度 (-100 到 100)\n     暗部范围 (5% 到 100%)\n     暗部羽化 (0 到 50)\n     亮部位置 (\"near\"=近处, \"far\"=远处)\n     亮部强度 (-100 到 100)\n     亮部范围 (5% 到 100%)\n     亮部羽化 (0 到 50)\n输出:\n     处理后的图像"
    },
    "ImageAnnotateWithPanel": {
        "title": "图像标注面板",
        "inputs": {
