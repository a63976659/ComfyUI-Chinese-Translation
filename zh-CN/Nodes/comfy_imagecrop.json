            "font_family": "字体族",
            "separator": "分隔符",
            "label_prefix": "标签前缀",
            "text_format": "文字格式",
            "annotations": "标注点",
            "selected_index": "选中索引",
            "font_mode": "字体模式",
            "font_weight": "字体粗细",
            "marker_color": "标记颜色",
            "text_color": "文字颜色"
        },
        "outputs": {
            "annotated_image": "标注后图像",
            "labels_text": "标签文字",
            "selected_label": "选中标签"
        },
        "description": "图像标注节点\n支持在图像上点击添加带编号的标记点"
