    "LTXTiledSampler": {
        "title": "LTX平铺采样器",
        "inputs": {
            "noise": "噪声",
            "guider": "引导器",
            "sampler": "采样器",
            "sigmas": "sigma",
            "latent_image": "Latent在图像"
        },
        "widgets": {
            "bypass_tiling": "跳过平铺",
            "tile_axis": "平铺轴",
            "n_tiles": "平铺数量",
            "tile_overlap": "平铺重叠",
            "max_size_for_no_tile": "无平铺的最大尺寸",
            "audio_pass": "音频通过",
            "audio_carrier_tile": "音频载体平铺",
            "debug": "调试"
        },
        "outputs": {
            "output": "输出",
            "denoised_output": "去噪输出"
        },
        "description": "适用于LTX2上采样阶段轻度细化的平铺式drop-in替换SamplerCustomAdvanced。每个平铺运行完整的训练分布token计数采样，然后余弦混合。仅用于轻度去噪。默认音频通过；audio_carrier_tile运行音频采样与一个选定的平铺同时进行（无需额外步骤）。设置bypass_tiling=true以作为标准单次采样的透明通过，适用于调试或不需要平铺的情况。"
    },
    "LTXVLatentUpsamplerTiled": {
