    "LTXLikenessGuide": {
        "title": "LTX相似性引导",
        "inputs": {
            "positive": "正向提示",
            "negative": "负向提示",
            "vae": "vae",
            "latent": "latent",
            "image": "参考图像"
        },
        "widgets": {
            "strength": "强度",
            "placement_mode": "放置模式",
            "face_detect": "人脸检测",
            "reference_mask_mode": "参考遮罩模式",
            "face_padding": "人脸填充",
            "crf": "CRF",
            "blur_radius": "模糊半径",
            "interpolation": "插值",
            "crop": "裁剪",
            "attention_strength": "注意力强度",
            "face_bbox_within_reference": "人脸边框在参考内",
            "emit_latent": "发射latent",
            "debug": "调试"
        },
        "outputs": {
            "positive": "正向提示",
            "negative": "负向提示",
            "latent": "latent",
            "reference_info": "参考信息"
        },
        "description": "附加相似性参考图像到条件设置以保存身份。发射修改后的正向/负向条件（用于Guider）和参考信息元数据（用于LikenessAnchor）。默认情况下，latent输出是对输入的通过——无需扩展，也无需裁剪。引导的价值来自于其与模型及其bbox元数据的条件交互，而不是来自latent修改。"
    },
    "LTXLikenessCrop": {
        "title": "LTX相似性裁剪",
        "inputs": {
            "latent": "latent",
            "reference_info": "参考信息"
        },
        "widgets": {
            "debug": "调试"
        },
        "outputs": {},
        "description": "在VAE解码前从Latent裁剪相似性参考帧。反转LTXLikenessGuide的emit_latent=扩展模式。仅当引导发出扩展latent时使用。若引导处于通过模式（默认），则无需使用此节点——可直接将latent连接至VAE解码。"
    },
