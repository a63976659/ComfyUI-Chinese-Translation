    "Flux2KleinDetailController": {
        "title": "Flux2Klein 细节控制器",
        "inputs": {
            "conditioning": "条件控制",
            "device": "运行设备"
        },
        "widgets": {
            "front_mult": "前部分倍率",
            "mid_mult": "中部分倍率",
            "end_mult": "后部分倍率",
            "emphasis_start": "强调起始位置",
            "emphasis_end": "强调结束位置",
            "emphasis_mult": "强调倍率",
            "preserve_original": "保留原始数据",
            "debug": "调试模式"
        },
        "outputs": {},
        "description": "分段嵌入倍率调节器。\n\n真实模式（推荐）：配合分段编码器使用。编码器会生成分段令牌范围作为条件控制元数据 (`meta[\"klein_sections\"]`)；本节点会按照用户设置的系数对对应范围内的激活嵌入进行倍率调整。\n\n兼容模式（旧版/不推荐）：如果不存在分段元数据，节点会自动将激活区域按照25%/50%/25%的固定比例分割。这些分割边界是任意的——Qwen3的令牌没有固定的位置语义——本节点v1版本在此模式下基本没有实际效果。保留此模式是为了兼容旧工作流；建议切换到分段编码器以获得有实际意义的分段感知缩放效果。"
    },
